      ]
    },
    "Send via Meta API": {
      "main": [[{ "node": "Log Outgoing Message", "type": "main", "index": 0 }]]
    },
    "Send via Evolution API": {
      "main": [[{ "node": "Log Outgoing Message", "type": "main", "index": 0 }]]
    },
    "Log Outgoing Message": {
      "main": [[{ "node": "Response OK", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionTimeout": 30
  }
}
